{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/log-prompt.mjs\"",
            "commandWindows": "node (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/log-prompt.mjs')",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/validate-harness-exec.mjs\"",
            "commandWindows": "node (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/validate-harness-exec.mjs')",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
